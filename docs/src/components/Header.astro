---
import type { Props } from '@astrojs/starlight/props';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
---
<div class="custom-header">
  <div class="header-left">
    <SiteTitle {...Astro.props} />
  </div>
  <div class="header-right">
    <nav class="custom-nav">
      <a href="/cortex/getting-started/">Documentation</a>
      <a href="https://github.com/avenka29/cortex">GitHub</a>
      <a href="https://npmjs.com/package/cortex-kb">NPM</a>
    </nav>
    <div class="search-wrap">
      <Search {...Astro.props} />
    </div>
  </div>
</div>

<style>
  .custom-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 1.5rem;
    height: 100%;
    border-bottom: 1px solid #222;
    background: #000;
  }
  .header-left, .header-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .custom-nav {
    display: flex;
    gap: 1.5rem;
  }
  .custom-nav a {
    color: #cccccc;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .custom-nav a:hover {
    color: #ffffff;
  }
  .search-wrap {
    display: flex;
    align-items: center;
  }
  
  @media (max-width: 768px) {
    .custom-nav {
      display: none;
    }
  }
</style>
